FROM rust:1.87-bookworm AS builder
WORKDIR /app

COPY Cargo.toml Cargo.lock ./
COPY crates ./crates
RUN cargo build --release -p gum-api

FROM debian:bookworm-slim
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates libssl3 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/target/release/gum-api /usr/local/bin/gum-api

ENV GUM_API_BIND_ADDR=0.0.0.0
ENV GUM_API_PORT=8080
EXPOSE 8080

CMD ["gum-api"]
